// ===================================================
// データ処理（ダイアログから呼ばれる）
// ===================================================
function processImportedData(params) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var master  = ss.getSheetByName(SHEET_MASTER);
    var history = ss.getSheetByName(SHEET_HISTORY);

    if (!master || !history) {
      return { success: false, error: '初期設定が完了していません。「⚙️ 初期設定」を実行してください。' };
    }

    // マスタを読み込みマップ化
    var masterData = master.getDataRange().getValues();
    var masterMap = {};
    for (var i = 1; i < masterData.length; i++) {
      var r = masterData[i];
      if (r[0]) masterMap[String(r[0])] = { rowIndex: i + 1, token: String(r[5]) };
    }

    var newMasterRows = [];
    var newHistoryRows = [];

    for (var c = 0; c < params.classes.length; c++) {
      var cls = params.classes[c];
      for (var ch = 0; ch < cls.children.length; ch++) {
        var child = cls.children[ch];
        var idStr = String(child.id);

        var token;
        if (masterMap[idStr]) {
          token = masterMap[idStr].token;
        } else {
          token = generateToken();
          var specialUrl = getWebAppUrl() + '?t=' + token;
          var qrUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(specialUrl);
          newMasterRows.push([child.id, child.guardianName, child.name, cls.name, '', token, new Date(), specialUrl, qrUrl]);
          masterMap[idStr] = { token: token };
        }

        newHistoryRows.push([
          String(params.invoiceMonth),
          child.id,
          child.guardianName,
          child.name,
          cls.name,
          JSON.stringify(child.fees),
          child.total,
          params.debitDate,
          params.notice || ''
        ]);
      }
    }

    // 同月データを削除（上書き更新）
    var hData = history.getDataRange().getValues();
    for (var i = hData.length - 1; i >= 1; i--) {
      if (String(hData[i][0]) === String(params.invoiceMonth)) history.deleteRow(i + 1);
    }

    // マスタに新規追加
    if (newMasterRows.length > 0) {
      master.getRange(master.getLastRow() + 1, 1, newMasterRows.length, 9).setValues(newMasterRows);
    }

    // 履歴に追加
    if (newHistoryRows.length > 0) {
      history.getRange(history.getLastRow() + 1, 1, newHistoryRows.length, 9).setValues(newHistoryRows);
    }

    return { success: true, count: newHistoryRows.length, newCount: newMasterRows.length };

  } catch(e) {
    return { success: false, error: e.message };
  }
}

// ===================================================
// トークン生成
// ===================================================
function generateToken() {
  var chars = 'abcdefghijklmnopqrstuvwxyz0123456789';
  var token = '';
  for (var i = 0; i < 14; i++) {
    token += chars[Math.floor(Math.random() * chars.length)];
  }
  return token;
}


var SHEET_MASTER  = 'マスタ';
var SHEET_HISTORY = '請求履歴';
var SHEET_SETTINGS = '設定';

// ===================================================
// メニュー追加
// ===================================================
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('🌿 請求管理')
    .addItem('📂 xlsmを取込む', 'showImportDialog')
    .addSeparator()
    .addItem('🔗 保護者ページURL一覧', 'showUrls')
    .addItem('📄 QRコード配布用ドキュメント生成', 'generateHandoutDoc')
    .addItem('👨‍👩‍👧 兄弟グループ一覧', 'showSiblingGroups')
    .addSeparator()
    .addItem('⚙️ 初期設定（初回のみ）', 'setup')
    .addSeparator()
    .addItem('🔄 マスタデータをリセット', 'resetMasterData')
    .addToUi();
}

// ===================================================
// 初期設定（初回のみ実行）
// ===================================================
function setup() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  PropertiesService.getScriptProperties().setProperty('SPREADSHEET_ID', ss.getId());

  // マスタシート作成（既存の場合もヘッダーを強制上書き）
  var m = ss.getSheetByName(SHEET_MASTER) || ss.insertSheet(SHEET_MASTER);
  m.getRange(1, 1, 1, 9).setValues([['園児ID', '保護者名', '園児名', 'クラス', '兄弟グループID', 'トークン', '登録日', '専用URL', 'QRコードURL']]);
  m.getRange(1, 1, 1, 9).setFontWeight('bold').setBackground('#e8f0ec');
  m.setFrozenRows(1);
  m.setColumnWidth(6, 160);
  m.setColumnWidth(8, 300);
  m.setColumnWidth(9, 300);

  // 請求履歴シート作成
  if (!ss.getSheetByName(SHEET_HISTORY)) {
    var h = ss.insertSheet(SHEET_HISTORY);
    h.getRange(1, 1, 1, 9).setValues([['年月', '園児ID', '保護者名', '園児名', 'クラス', '費用詳細(JSON)', '合計金額', '引き落とし日', 'お知らせ']]);
    h.getRange(1, 1, 1, 9).setFontWeight('bold').setBackground('#e8f0ec');
    h.setFrozenRows(1);
    h.setColumnWidth(6, 300);
  }

  // 設定シート作成
  if (!ss.getSheetByName(SHEET_SETTINGS)) {
    var s = ss.insertSheet(SHEET_SETTINGS);
    s.getRange('A1:B3').setValues([
      ['保育園名', 'リトルガーデンしいのみ'],
      ['担当者名', '本木'],
      ['備考', '']
    ]);
    s.getRange('A1:A3').setFontWeight('bold');
  }

  SpreadsheetApp.getUi().alert('✅ 初期設定が完了しました！\n\n次に：\n1. 設定シートで保育園名・担当者名を確認\n2. このスクリプトをウェブアプリとして公開\n（拡張機能→Apps Script→デプロイ→新しいデプロイ）\n\n⚠️ マスタシートのデータが古い場合は\n「🔄 マスタデータをリセット」を実行してから\nxlsmを再取込みしてください。');
}

